RENTAL_DASHBOARD_DB_PATH=data/renter.db
RENTAL_DASHBOARD_BACKUP_DIR=backups
RENTAL_DASHBOARD_LOG_DIR=logs
RENTAL_DASHBOARD_EXPORT_DIR=exports
RENTAL_DASHBOARD_HOST=127.0.0.1
RENTAL_DASHBOARD_PORT=8000
RENTAL_DASHBOARD_APPROVED_FEED_PATH=app/data/approved_provider_feed.json
RENTAL_DASHBOARD_DISCOVERY_DEFAULT_CITIES=Irvine,Tustin,Lake Forest,Costa Mesa,Fullerton,Anaheim,Huntington Beach,Mission Viejo,Orange

# Optional provider API discovery. Disabled unless enabled and a key is set.
RENTAL_DASHBOARD_RENTCAST_ENABLED=false
RENTAL_DASHBOARD_RENTCAST_API_KEY=
# RENTCAST_API_KEY is also accepted as an alias.
RENTAL_DASHBOARD_RENTCAST_API_BASE_URL=https://api.rentcast.io/v1
RENTAL_DASHBOARD_RENTCAST_TIMEOUT_SECONDS=12

# Future placeholders only. Do not enable without compliance review and tests.
APIFY_API_TOKEN=
BRIGHTDATA_API_KEY=
